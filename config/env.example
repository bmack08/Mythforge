# Mythwright Environment Configuration
# Copy this file to config/.env and fill in your actual values

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=sqlite:./mythwright.db
NODE_ENV=development

# Server Configuration
PORT=3000
FRONTEND_PORT=3001

# AI Configuration
AI_MODEL_DEFAULT=gpt-4o-mini
AI_MODEL_PREMIUM=gpt-4o
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Budget Configuration
AI_DAILY_BUDGET_USD=10.00
AI_COST_TRACKING_ENABLED=true

# Legal Compliance
COMMERCIAL_MODE=false
PI_FILTERING_ENABLED=true
SRD_COMPLIANCE_STRICT=true
